# SPDX-License-Identifier: Apache-2.0
FROM node:22-slim

# Install git (needed for entrypoint auto-init). curl is commonly needed by LLMs
# to download tools.
RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Install opencode globally from npm
RUN npm install -g opencode-ai

# The node:22-slim base image already provides a 'node' user (UID 1000) with
# home /home/node. We reuse this standard convention rather than creating a
# separate user, which keeps UID/GID consistent and avoids permission issues
# when the host mounts XDG directories into the container.
RUN mkdir -p /code && \
    mkdir -p /home/node/.local/share /home/node/.local/state /home/node/.cache && \
    chown -R node:node /code /home/node/.local /home/node/.cache

WORKDIR /code

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER node

ENTRYPOINT ["/entrypoint.sh"]
