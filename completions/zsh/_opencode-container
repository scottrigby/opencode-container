# opencode-container zsh completion

autoload -Uz compinit && compinit

_opencode_container() {
  local -a opts cmds web_opts
  opts=(
    '-b' '--build'
    '-f' '--feature-file'
    '-e' '--env-file'
    '-w' '--web'
    '-p' '--port'
    '--no-open'
    '--no-git-root'
    '--no-git-init'
    '-h' '--help'
  )
  cmds=(
    'completion'
    'projects'
  )
  web_opts=(
    '-p' '--port'
    '--no-open'
  )

  # Determine current context
  local cmd=""
  local web_seen=false
  local i
  for (( i=2; i <= CURRENT; i++ )); do
    case "${words[i]}" in
      --) break ;;
      -b|--build|--no-git-root|--no-git-init|-h|--help) continue ;;
      -f|--feature-file|-e|--env-file) (( i++ )); continue ;;
      -w|--web) web_seen=true; continue ;;
      -p|--port) (( i++ )); continue ;;
      --no-open|--bash|--zsh) continue ;;
      completion|projects) cmd="${words[i]}"; break ;;
      *) break ;;
    esac
  done

  if [[ -n "$cmd" ]]; then
    case "$cmd" in
      completion)
        compadd --bash --zsh
        ;;
      projects)
        ;;
    esac
    return
  fi

  # No command yet — offer main opts + cmds
  compadd -a opts
  compadd -a cmds

  # If web mode already seen, also offer web opts
  if [[ "$web_seen" == true ]]; then
    compadd -a web_opts
  fi
}

compdef _opencode_container opencode-container
