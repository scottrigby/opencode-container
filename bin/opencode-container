#!/bin/bash
# SPDX-License-Identifier: Apache-2.0
set -euo pipefail


# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
IMAGE="localhost/opencode-container"
DEFAULT_PORT=4096
LABEL_KEY="opencode.project.id"

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
  cat <<'EOF'
NAME
    opencode-container — run opencode in a Podman container with per-project isolation

SYNOPSIS
    opencode-container [options] [command] [command-options]
    opencode-container [options] [--] [opencode-args...]

DESCRIPTION
    A wrapper around podman (or the devcontainer CLI) that runs the opencode
    CLI in a Debian-based (node:22-slim) container with per-project data
    isolation.

    When --feature-file is given, the wrapper uses the devcontainer CLI to
    layer devcontainer features (Node, Python, Go, etc.) on top of the base
    image. Without --feature-file, the container starts directly via Podman
    for a fast path.

OPTIONS
    -h, --help           Print this help and exit
    -b, --build          Force rebuild the container image before running
    -f, --feature-file PATH
                         Merge .features from a JSON file into the generated
                         devcontainer.json. Repeatable; later files win on
                         key collision. Requires npx (auto-installs
                         @devcontainers/cli and node-jq on first use).
    -e, --env-file PATH  Pass an environment file to the container.
                         Repeatable. Auto-detects .env in project root.
    -w, --web            Run in web UI mode instead of TUI (default)
    -p, --port PORT      Port to listen on (web mode only; default: 4096)
    --no-open            Do not auto-open the browser (web mode only)
    --no-git-root        Mount the current working directory instead of
                         auto-detecting the git repository root
    --no-git-init        Do not auto-initialise an empty git repo in
                         non-git directories

COMMANDS
    projects             List all projects with isolated session data
    completion           Generate shell completion scripts

COMMAND OPTIONS
    completion
        --bash             Output bash completion script
        --zsh              Output zsh completion script

EXAMPLES
    opencode-container                      # TUI mode
    opencode-container -w                     # Web mode
    opencode-container -w -p 5000           # Web mode on port 5000
    opencode-container -b -w -p 5000         # Rebuild, then web on 5000
    opencode-container --no-git-root          # TUI, mount current dir
    opencode-container -f ./features.json -w
    opencode-container projects               # List isolated projects
    opencode-container completion --bash      # Bash completion script
    opencode-container completion --zsh       # Zsh completion script

See docs/commands.md for full documentation.
EOF
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

resolve_path() {
  (cd "$1" && pwd -P) 2>/dev/null || printf '%s\n' "$1"
}

build_image() {
  local container_dir="$1"
  local dockerfile="${container_dir}/Containerfile.debian"
  if [[ ! -f "$dockerfile" ]]; then
    echo "Image ${IMAGE} not found and no ${dockerfile}" >&2
    echo "Please run: podman build -t ${IMAGE} -f ${dockerfile} ${container_dir}" >&2
    exit 1
  fi
  echo "Building ${IMAGE} ..." >&2
  podman build -t "${IMAGE}" -f "${dockerfile}" "${container_dir}" >&2
}

find_free_port() {
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    while lsof -Pi :${port} -sTCP:LISTEN -t >/dev/null 2>&1; do
      port=$((port + 1))
    done
  elif command -v ss >/dev/null 2>&1; then
    while ss -tln 2>/dev/null | grep -q "LISTEN.*:${port} "; do
      port=$((port + 1))
    done
  fi
  echo "$port"
}

# Returns 0 if the TCP port is accepting connections
port_is_open() {
  local host="$1" port="$2"
  timeout 2 bash -c "exec 3<>/dev/tcp/${host}/${port}" 2>/dev/null
}

# ---------------------------------------------------------------------------
# Phase 1: intercept --help / -h anywhere in the argument list
# ---------------------------------------------------------------------------
for arg in "$@"; do
  if [[ "$arg" == "--help" ]] || [[ "$arg" == "-h" ]]; then
    usage
    exit 0
  fi
done


# ---------------------------------------------------------------------------
# Phase 2: parse options
# ---------------------------------------------------------------------------
FORCE_BUILD=false
NO_GIT_ROOT=false
NO_GIT_INIT=false
WEB_MODE=false
WEB_PORT="$DEFAULT_PORT"
WEB_NO_OPEN=false
FEATURE_FILES=()
ENV_FILES=()
OPENCODE_EXTRA_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --build|-b)
      FORCE_BUILD=true
      shift
      ;;
    --feature-file|-f)
      if [[ -n "${2:-}" ]] && [[ "${2:-}" != -* ]]; then
        FEATURE_FILES+=("$2")
        shift 2
      else
        echo "Error: --feature-file requires an argument" >&2
        exit 1
      fi
      ;;
    --env-file|-e)
      if [[ -n "${2:-}" ]] && [[ "${2:-}" != -* ]]; then
        ENV_FILES+=("$2")
        shift 2
      else
        echo "Error: --env-file requires an argument" >&2
        exit 1
      fi
      ;;
    --web|-w)
      WEB_MODE=true
      shift
      ;;
    --port|-p)
      if [[ -n "${2:-}" ]] && [[ "${2:-}" != -* ]]; then
        WEB_PORT="$2"
        shift 2
      else
        echo "Error: --port requires an argument" >&2
        exit 1
      fi
      ;;
    --no-open)
      WEB_NO_OPEN=true
      shift
      ;;
    --bash)
      COMPLETION_SHELL="bash"
      shift
      ;;
    --zsh)
      COMPLETION_SHELL="zsh"
      shift
      ;;
    --no-git-root)
      NO_GIT_ROOT=true
      shift
      ;;
    --no-git-init)
      NO_GIT_INIT=true
      shift
      ;;
    --)
      shift
      OPENCODE_EXTRA_ARGS+=("$@")
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      # First non-option arg: check if it's a command
      if [[ -z "${COMMAND:-}" ]] && ([[ "$1" == "projects" ]] || [[ "$1" == "completion" ]]); then
        COMMAND="$1"
        shift
        # Don't break — continue parsing to handle command options like --bash/--zsh
        continue
      fi
      # Otherwise, it's an opencode arg
      OPENCODE_EXTRA_ARGS+=("$1")
      shift
      ;;
  esac
done


# ---------------------------------------------------------------------------
# Subcommand: projects (no container needed)
# ---------------------------------------------------------------------------
if [[ "${COMMAND:-}" == "projects" ]]; then
  DATA_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/opencode"
  if [[ ! -d "$DATA_ROOT" ]]; then
    echo "No projects found in $DATA_ROOT" >&2
    exit 0
  fi

  decode_base64url() {
    local input="$1"
    local len=${#input}
    local mod=$((len % 4))
    local padding=""
    if [[ $mod -eq 2 ]]; then
      padding="=="
    elif [[ $mod -eq 3 ]]; then
      padding="="
    fi
    printf '%s%s\n' "$input" "$padding" | tr '_-' '/+' | base64 --decode
  }

  for d in "$DATA_ROOT"/*; do
    [[ -d "$d" ]] || continue
    basename="$(basename "$d")"
    decoded="$(decode_base64url "$basename" 2>/dev/null)"
    if [[ -z "$decoded" ]]; then
      echo "[unreadable]  $basename" >&2
      continue
    fi
    # Resolve symlinks for consistent display (macOS: /var → /private/var)
    if [[ -d "$decoded" ]]; then
      decoded="$(cd "$decoded" && pwd -P)"
    fi
    echo "$decoded"
  done
  exit 0
fi


# ---------------------------------------------------------------------------
# Subcommand: completion (no container needed)
# ---------------------------------------------------------------------------
if [[ "${COMMAND:-}" == "completion" ]]; then
  if [[ -z "${COMPLETION_SHELL:-}" ]]; then
    cat <<'EOF'
Generate shell completion scripts for opencode-container.

Usage: opencode-container completion [--bash|--zsh]

  --bash    Output bash completion script
  --zsh     Output zsh completion script

Examples:
  opencode-container completion --bash > /etc/bash_completion.d/opencode-container
  opencode-container completion --zsh > "${fpath[1]}/_opencode-container"

Completion files are also available directly:
  completions/bash/opencode-container
  completions/zsh/_opencode-container
EOF
    exit 0
  fi

  # Resolve script directory, even if installed via symlink.
  SCRIPT_PATH="$0"
  while [[ -L "$SCRIPT_PATH" ]]; do
    LINK_TARGET=$(readlink "$SCRIPT_PATH")
    if [[ "$LINK_TARGET" == /* ]]; then
      SCRIPT_PATH="$LINK_TARGET"
    else
      SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$LINK_TARGET"
    fi
  done
  SCRIPT_DIR=$(cd "$(dirname "$SCRIPT_PATH")" && pwd)

  if [[ "$COMPLETION_SHELL" == "bash" ]]; then
    cat "$SCRIPT_DIR/../completions/bash/opencode-container"
  elif [[ "$COMPLETION_SHELL" == "zsh" ]]; then
    cat "$SCRIPT_DIR/../completions/zsh/_opencode-container"
  fi
  exit 0
fi

# ---------------------------------------------------------------------------
# Container setup (common to tui and web)
# ---------------------------------------------------------------------------

# Resolve script directory, even if installed via symlink.
SCRIPT_PATH="$0"
while [[ -L "$SCRIPT_PATH" ]]; do
  LINK_TARGET=$(readlink "$SCRIPT_PATH")
  if [[ "$LINK_TARGET" == /* ]]; then
    SCRIPT_PATH="$LINK_TARGET"
  else
    SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$LINK_TARGET"
  fi
done
SCRIPT_DIR=$(cd "$(dirname "$SCRIPT_PATH")" && pwd)
CONTAINER_DIR="$(cd "$SCRIPT_DIR/../container" && pwd)"

# Resolve symlinks in a path (macOS: /var → /private/var, etc.).
PWD_RESOLVED=$(resolve_path "$PWD")

# Detect git root on the host. If we're inside a git repo, mount the repo root
# as /code so the container can discover .git and correctly identify the project.
GIT_ROOT=""
if [[ "$NO_GIT_ROOT" == false ]] && command -v git >/dev/null 2>&1; then
  GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
fi

if [[ -n "${GIT_ROOT:-}" ]]; then
  CODE_DIR=$(resolve_path "$GIT_ROOT")
  PROJECT_ID=$(echo -n "$CODE_DIR" | base64 | tr -d '\n' | tr '+/' '-_' | tr -d '=')
else
  CODE_DIR="$PWD_RESOLVED"
  PROJECT_ID=$(echo -n "$PWD_RESOLVED" | base64 | tr -d '\n' | tr '+/' '-_' | tr -d '=')
fi

DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/opencode/$PROJECT_ID"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/$PROJECT_ID"

if [[ -n "${GIT_ROOT:-}" ]] && [[ "$CODE_DIR" != "$PWD_RESOLVED" ]]; then
  echo "Git repo detected; mounting root: $CODE_DIR" >&2
fi

mkdir -p "$DATA_DIR" "$CONFIG_DIR"

# Auto-detect .env file in project root (CODE_DIR)
if [[ -f "$CODE_DIR/.env" ]]; then
  ENV_FILES+=("$CODE_DIR/.env")
  echo "Auto-detected env file: $CODE_DIR/.env" >&2
fi


# Hint if the project has its own .devcontainer directory
if [[ -f "$CODE_DIR/.devcontainer/devcontainer.json" ]]; then
  echo "Hint: Found .devcontainer/devcontainer.json — use --feature-file .devcontainer/devcontainer.json to include its features" >&2
fi

# ---------------------------------------------------------------------------
# Path B: Devcontainer mode (when --feature-file is given)
# ---------------------------------------------------------------------------
if [[ ${#FEATURE_FILES[@]} -gt 0 ]]; then
  # Requirements check: resolve devcontainer CLI (global or via npx)
  DEVCONTAINER_CMD=()
  if command -v devcontainer >/dev/null 2>&1; then
    DEVCONTAINER_CMD=(devcontainer)
  elif command -v npx >/dev/null 2>&1 && npx --yes @devcontainers/cli --version >/dev/null 2>&1; then
    DEVCONTAINER_CMD=(npx --yes @devcontainers/cli)
  fi
  if [[ ${#DEVCONTAINER_CMD[@]} -eq 0 ]]; then
    echo "Error: devcontainer CLI is required for --feature-file." >&2
    echo "Install one of:" >&2
    echo "  npm install -g npx                     (recommended — auto-installs on first use)" >&2
    echo "  npm install -g @devcontainers/cli    (global install)" >&2
    exit 1
  fi

  # Requirements check: jq via npx node-jq (deterministic, cross-platform)
  if ! command -v npx >/dev/null 2>&1; then
    echo "Error: npx is required for --feature-file." >&2
    echo "Install with: npm install -g npx" >&2
    exit 1
  fi
  JQ_CMD=(npx --yes node-jq)

  # Build base image if needed (skip if podman isn't available)
  if [[ "$FORCE_BUILD" == true ]] || ( command -v podman >/dev/null 2>&1 && ! podman image exists "$IMAGE" >/dev/null 2>&1 ); then
    build_image "$CONTAINER_DIR"
  fi

  # Prevent duplicate containers for the same project (skip if podman unavailable)
  if command -v podman >/dev/null 2>&1; then
    RUNNING_NAME=$(podman ps --filter "label=${LABEL_KEY}=${PROJECT_ID}" --format '{{.Names}}' | head -n1)
    if [[ -n "$RUNNING_NAME" ]]; then
      echo "opencode is already running for this project: ${RUNNING_NAME}" >&2
      exit 1
    fi
  fi

  # Merge features from all --feature-file args.
  # TODO: Consider also merging other devcontainer.json keys (e.g. cacheEnv
  # for persistent dependency caches, or extraDomains for firewall rules)
  # from feature files. Each tool has its own env var conventions
  # (npm_config_cache, PIP_CACHE_DIR, GOMODCACHE, etc.).
  MERGED_FEATURES='{}'
  for f in "${FEATURE_FILES[@]}"; do
    if [[ ! -f "$f" ]]; then
      echo "Error: feature file not found: $f" >&2
      exit 1
    fi
    # Validate it's valid JSON with a .features key (or at least valid JSON)
    if ! "${JQ_CMD[@]}" empty "$f" 2>/dev/null; then
      echo "Error: invalid JSON in feature file: $f" >&2
      exit 1
    fi
    # Merge .features if present, otherwise skip
    local_file_features=$("${JQ_CMD[@]}" -r '.features // {}' "$f")
    MERGED_FEATURES=$(echo "$MERGED_FEATURES" "$local_file_features" | "${JQ_CMD[@]}" -s '.[0] * .[1]')
  done

  # Prepare cache directory for generated devcontainer.json
  CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/opencode/$PROJECT_ID"
  mkdir -p "$CACHE_DIR"
  DEVCONTAINER_JSON="$CACHE_DIR/devcontainer.json"

  # Build forwardPorts and port bindings for web mode
  FORWARD_PORTS='[]'
  EXTRA_RUNARGS='[]'
  if [[ "$WEB_MODE" == true ]]; then
    PORT=$(find_free_port "$WEB_PORT")
    if [[ "$PORT" != "$WEB_PORT" ]]; then
      echo "Port ${WEB_PORT} in use, using port ${PORT} instead" >&2
    fi
    FORWARD_PORTS="[$PORT]"
    EXTRA_RUNARGS="[\"-p=${PORT}:${PORT}\"]"
  fi

  # Build env-file args for devcontainer.json runArgs
  ENV_ARGS='[]'
  if [[ ${#ENV_FILES[@]} -gt 0 ]]; then
    env_json=""
    for f in "${ENV_FILES[@]}"; do
      if [[ -n "$env_json" ]]; then
        env_json+=","
      fi
      # Escape backslashes and quotes for JSON using jq
      escaped_f=$(printf '%s' "$f" | npx --yes node-jq -Rr '@json')
      env_json+="\"--env-file\",$escaped_f"
    done
    ENV_ARGS="[$env_json]"
  fi

  # Build environment map (values MUST be strings per devcontainer spec)
  if [[ "$NO_GIT_INIT" == true ]]; then
    CONTAINER_ENV='{"OPENCODE_DISABLE_DEFAULT_PLUGINS":"true","OPENCODE_NO_GIT_INIT":"1"}'
  else
    CONTAINER_ENV='{"OPENCODE_DISABLE_DEFAULT_PLUGINS":"true"}'
  fi

  # Generate devcontainer.json via jq.  All env values are strings (spec
  # requirement); features key is omitted when empty to avoid CLI bugs.
  # build.options "--progress=plain" suppresses BuildKit TUI ANSI cursor
  # sequences that corrupt the terminal after devcontainer up completes.
  "${JQ_CMD[@]}" -n \
    --arg image "$IMAGE" \
    --argjson features "$MERGED_FEATURES" \
    --argjson forwardPorts "$FORWARD_PORTS" \
    --argjson extraRunArgs "$EXTRA_RUNARGS" \
    --argjson envArgs "$ENV_ARGS" \
    --arg label "${LABEL_KEY}=${PROJECT_ID}" \
    --arg dataDir "$DATA_DIR" \
    --arg configDir "$CONFIG_DIR" \
    --arg codeDir "$CODE_DIR" \
    --argjson containerEnv "$CONTAINER_ENV" \
    '{
      name: "opencode-container",
      image: $image,
      build: {
        options: ["--progress=plain"]
      },
      forwardPorts: $forwardPorts,
      containerEnv: $containerEnv,
      mounts: [
        {source: $dataDir, target: "/home/node/.local/share/opencode", type: "bind"},
        {source: $configDir, target: "/home/node/.config/opencode", type: "bind"},
        {source: $codeDir, target: "/code", type: "bind"}
      ],
      runArgs: (
        ["--label=" + $label] +
        ["--init"] +
        $envArgs +
        $extraRunArgs
      ),
      overrideCommand: false,
      remoteUser: "node"
    } + (if ($features | keys | length) > 0 then {features: $features} else {} end)' > "$DEVCONTAINER_JSON"

  echo "Generated devcontainer config: $DEVCONTAINER_JSON" >&2

  # Start the devcontainer. Capture stdout silently (JSON result) while
  # streaming stderr live so the user sees feature build progress.  This matches
  # claudeman's approach — no silent waiting.
  UP_STDOUT="$(mktemp)"
  echo "Starting devcontainer... (features may take time to build)" >&2
  if ! "${DEVCONTAINER_CMD[@]}" up \
    --docker-path podman \
    --workspace-folder "$CODE_DIR" \
    --config "$DEVCONTAINER_JSON" \
    --remove-existing-container \
    >"$UP_STDOUT"; then
    echo "Error: devcontainer up failed" >&2
    rm -f "$UP_STDOUT"
    exit 1
  fi
  rm -f "$UP_STDOUT"

  # Find container ID by label for cleanup
  CONTAINER_ID=$(podman ps --filter "label=${LABEL_KEY}=${PROJECT_ID}" --format '{{.ID}}' | head -n1)

  cleanup_devcontainer() {
    trap - EXIT INT TERM
    echo ""
    echo "Stopping opencode container..." >&2
    local cid
    cid=$(podman ps --filter "label=${LABEL_KEY}=${PROJECT_ID}" --format '{{.ID}}' | head -n1)
    if [[ -n "$cid" ]]; then
      "${DEVCONTAINER_CMD[@]}" stop \
        --docker-path podman \
        --workspace-folder "$CODE_DIR" \
        --config "$DEVCONTAINER_JSON" \
        >/dev/null 2>&1 || true
      podman rm -f "$cid" >/dev/null 2>&1 || true
    fi
  }
  trap cleanup_devcontainer EXIT INT TERM

  if [[ "$WEB_MODE" == true ]]; then
    CODE_B64=$(printf '%s' '/code' | base64 | tr -d '\n' | tr '+/' '-_' | tr -d '=')
    URL="http://localhost:${PORT}/${CODE_B64}"
    echo "URL: ${URL}"

    # Wait for HTTP port
    echo -n "Waiting for server to start" >&2
    http_ready=false
    for _ in $(seq 1 30); do
      if port_is_open localhost "$PORT"; then
        http_ready=true
        break
      fi
      echo -n "." >&2
      sleep 1
    done
    echo "" >&2

    if [[ "$http_ready" == false ]]; then
      echo "Warning: server did not respond on port ${PORT}" >&2
    fi

    if [[ "$http_ready" == true ]] && [[ "$WEB_NO_OPEN" == false ]]; then
      if command -v open >/dev/null 2>&1; then
        open "$URL"
      elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$URL"
      fi
    fi

    # Keep the container running; devcontainer exec web mode runs in foreground.
    # Ctrl+C kills the exec process; the EXIT/INT trap cleans up the container.
    "${DEVCONTAINER_CMD[@]}" exec \
      --docker-path podman \
      --workspace-folder "$CODE_DIR" \
      --config "$DEVCONTAINER_JSON" \
      opencode web --hostname 0.0.0.0 --port "$PORT" \
      "${OPENCODE_EXTRA_ARGS[@]+"${OPENCODE_EXTRA_ARGS[@]}"]}" || true
  else
    # TUI mode -- devcontainer exec inherits TTY from parent process
    # automatically; do not pass --tty (not a valid exec flag).
    "${DEVCONTAINER_CMD[@]}" exec \
      --docker-path podman \
      --workspace-folder "$CODE_DIR" \
      --config "$DEVCONTAINER_JSON" \
      opencode \
      "${OPENCODE_EXTRA_ARGS[@]+"${OPENCODE_EXTRA_ARGS[@]}"]}"
  fi

  exit 0
fi

# ---------------------------------------------------------------------------
# Path A: Fast path (direct podman run — no devcontainer features)
# ---------------------------------------------------------------------------

# Auto-build the image on first run, or when --build is passed.
if [[ "$FORCE_BUILD" == true ]] || ! podman image exists "$IMAGE" >/dev/null 2>&1; then
  build_image "$CONTAINER_DIR"
fi

# Prevent duplicate containers for the same project using the full label value
RUNNING_NAME=$(podman ps --filter "label=${LABEL_KEY}=${PROJECT_ID}" --format '{{.Names}}' | head -n1)
if [[ -n "$RUNNING_NAME" ]]; then
  echo "opencode is already running for this project: ${RUNNING_NAME}" >&2
  exit 1
fi

# Common podman args (no --name — let Podman auto-generate to avoid collisions)
PODMAN_ARGS=(
  --label "${LABEL_KEY}=${PROJECT_ID}"
  -v "${DATA_DIR}:/home/node/.local/share/opencode:Z"
  -v "${CONFIG_DIR}:/home/node/.config/opencode:Z"
  -v "${CODE_DIR}:/code:Z"
  -e OPENCODE_DISABLE_DEFAULT_PLUGINS=true
  -e XDG_DATA_HOME=/home/node/.local/share
  -e XDG_CONFIG_HOME=/home/node/.config
  -e XDG_CACHE_HOME=/home/node/.cache
  -e XDG_STATE_HOME=/home/node/.local/state
)

if [[ "$NO_GIT_INIT" == true ]]; then
  PODMAN_ARGS+=(-e OPENCODE_NO_GIT_INIT=1)
fi

# Add env-file args for Podman
for f in "${ENV_FILES[@]}"; do
  PODMAN_ARGS+=(--env-file "$f")
done

# ---------------------------------------------------------------------------
# Web mode (fast path)
# ---------------------------------------------------------------------------
if [[ "$WEB_MODE" == true ]]; then
  PORT=$(find_free_port "$WEB_PORT")
  if [[ "$PORT" != "$WEB_PORT" ]]; then
    echo "Port ${WEB_PORT} in use, using port ${PORT} instead" >&2
  fi

  # Start container in background
  podman run -i --rm --init \
    "${PODMAN_ARGS[@]}" \
    -p "${PORT}:${PORT}" \
    "${IMAGE}" \
    web --hostname 0.0.0.0 --port "${PORT}" \
    "${OPENCODE_EXTRA_ARGS[@]+"${OPENCODE_EXTRA_ARGS[@]}"]}" &
  CONTAINER_PID=$!

  # Wait briefly for Podman to register the container, then look up its name
  CONTAINER_NAME=""
  for _ in $(seq 1 20); do
    CONTAINER_NAME=$(podman ps --filter "label=${LABEL_KEY}=${PROJECT_ID}" --format '{{.Names}}' | head -n1)
    [[ -n "$CONTAINER_NAME" ]] && break
    sleep 0.1
  done

  if [[ -z "$CONTAINER_NAME" ]]; then
    echo "Error: container failed to start" >&2
    kill $CONTAINER_PID 2>/dev/null || true
    wait $CONTAINER_PID 2>/dev/null || true
    exit 1
  fi

  CODE_B64=$(printf '%s' '/code' | base64 | tr -d '\n' | tr '+/' '-_' | tr -d '=')
  URL="http://localhost:${PORT}/${CODE_B64}"

  echo "opencode web container: ${CONTAINER_NAME}"

  # Wait for the HTTP port to be responsive before opening browser
  echo -n "Waiting for server to start" >&2
  http_ready=false
  for _ in $(seq 1 30); do
    if port_is_open localhost "$PORT"; then
      http_ready=true
      break
    fi
    echo -n "." >&2
    sleep 1
  done
  echo "" >&2

  if [[ "$http_ready" == false ]]; then
    echo "Warning: server did not respond on port ${PORT}" >&2
  fi

  echo "URL: ${URL}"

  # Auto-open browser only if port is ready and --no-open was not passed
  if [[ "$http_ready" == true ]] && [[ "$WEB_NO_OPEN" == false ]]; then
    if command -v open >/dev/null 2>&1; then
      open "$URL"
    elif command -v xdg-open >/dev/null 2>&1; then
      xdg-open "$URL"
    fi
  fi

  cleanup() {
    trap - EXIT INT TERM
    echo ""
    echo "Stopping opencode container..." >&2
    local name
    name=$(podman ps --filter "label=${LABEL_KEY}=${PROJECT_ID}" --format '{{.Names}}' | head -n1)
    if [[ -n "$name" ]]; then
      podman stop -t 5 "$name" >/dev/null 2>&1 || true
    fi
    wait $CONTAINER_PID 2>/dev/null || true
  }
  trap cleanup EXIT INT TERM

  # Wait for container; || true prevents set -e from skipping cleanup
  wait $CONTAINER_PID || true

# ---------------------------------------------------------------------------
# TUI mode (default)
# ---------------------------------------------------------------------------
else
  podman run -it --rm \
    "${PODMAN_ARGS[@]}" \
    "${IMAGE}" \
    "${OPENCODE_EXTRA_ARGS[@]+"${OPENCODE_EXTRA_ARGS[@]}"]}"
fi
