#!/bin/bash
# SPDX-License-Identifier: Apache-2.0
set -euo pipefail

IMAGE="localhost/opencode-container"
REQUESTED_PORT="${OPENCODE_PORT:-4096}"
FORCE_BUILD=false

# Strip --build from args before passing them to opencode
REST_ARGS=()
for arg in "$@"; do
  if [[ "$arg" == "--build" ]]; then
    FORCE_BUILD=true
  else
    REST_ARGS+=("$arg")
  fi
done
set -- "${REST_ARGS[@]:-}"

if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
  cat <<'EOF'
NAME
    opencode-container — run opencode in a Podman container with per-project isolation

SYNOPSIS
    opencode-container [--build] [subcommand]

COMMANDS
    tui          Terminal UI mode (default when no subcommand is given)
    web          Web UI mode — auto-discovers a free port starting at 4096
    projects     List all projects with isolated session data

OPTIONS
    --build      Force rebuild the container image before running
    --help, -h   Print this help and exit

ENVIRONMENT
    OPENCODE_PORT          Override the default web port (4096)
    OPENCODE_NO_GIT_ROOT=1  Mount current dir instead of git repo root
    XDG_DATA_HOME          Base dir for session data (default: ~/.local/share)
    XDG_CONFIG_HOME        Base dir for project config (default: ~/.config)

EXAMPLES
    opencode-container                  # TUI mode
    opencode-container web              # Web mode
    OPENCODE_PORT=5000 opencode-container web
    opencode-container --build web      # Rebuild image, then web mode
    opencode-container projects         # List isolated projects

See docs/commands.md for full documentation.
EOF
  exit 0
fi

# --- Subcommands that don't start a container ---

if [[ "${1:-}" == "projects" ]]; then
  DATA_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/opencode"
  if [[ ! -d "$DATA_ROOT" ]]; then
    echo "No projects found in $DATA_ROOT" >&2
    exit 0
  fi

  decode_base64url() {
    local input="$1"
    local len=${#input}
    local mod=$((len % 4))
    local padding=""
    if [[ $mod -eq 2 ]]; then
      padding="=="
    elif [[ $mod -eq 3 ]]; then
      padding="="
    fi
    printf '%s%s\n' "$input" "$padding" | tr '_-' '/+' | base64 --decode
  }

  for d in "$DATA_ROOT"/*; do
    [[ -d "$d" ]] || continue
    basename="$(basename "$d")"
    decoded="$(decode_base64url "$basename" 2>/dev/null)"
    if [[ -z "$decoded" ]]; then
      echo "[unreadable]  $basename" >&2
      continue
    fi
    # Resolve symlinks for consistent display (macOS: /var → /private/var)
    if [[ -d "$decoded" ]]; then
      decoded="$(cd "$decoded" && pwd -P)"
    fi
    echo "$decoded"
  done
  exit 0
fi

# Resolve script directory, even if installed via symlink.
# Works on macOS (no readlink -f) and Linux.
SCRIPT_PATH="$0"
while [[ -L "$SCRIPT_PATH" ]]; do
  LINK_TARGET=$(readlink "$SCRIPT_PATH")
  if [[ "$LINK_TARGET" == /* ]]; then
    SCRIPT_PATH="$LINK_TARGET"
  else
    SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$LINK_TARGET"
  fi
done
SCRIPT_DIR=$(cd "$(dirname "$SCRIPT_PATH")" && pwd)
CONTAINER_DIR="$(cd "$SCRIPT_DIR/../container" && pwd)"

# Auto-build the image on first run, or when --build is passed.
if [[ "$FORCE_BUILD" == true ]] || ! podman image exists "$IMAGE" >/dev/null 2>&1; then
  if [[ ! -f "$CONTAINER_DIR/Containerfile" ]]; then
    echo "Image $IMAGE not found and no Containerfile in $CONTAINER_DIR" >&2
    echo "Please run: podman build -t $IMAGE $CONTAINER_DIR" >&2
    exit 1
  fi
  echo "Building $IMAGE ..." >&2
  podman build -t "$IMAGE" "$CONTAINER_DIR" >&2
fi

# Detect web mode early so we can skip port scanning for TUI/subcommands
IS_WEB=false
for arg in "$@"; do
  if [[ "$arg" == "web" ]]; then
    IS_WEB=true
    break
  fi
done

# Find next free port (macOS: lsof, Linux: ss) — only needed for web mode
if [[ "$IS_WEB" == true ]]; then
  find_free_port() {
      local port="$1"
      if command -v lsof >/dev/null 2>&1; then
          while lsof -Pi :${port} -sTCP:LISTEN -t >/dev/null 2>&1; do
              port=$((port + 1))
          done
      elif command -v ss >/dev/null 2>&1; then
          while ss -tln 2>/dev/null | grep -q "LISTEN.*:${port} "; do
              port=$((port + 1))
          done
      fi
      echo "$port"
  }

  PORT=$(find_free_port "$REQUESTED_PORT")
  if [[ "$PORT" != "$REQUESTED_PORT" ]]; then
      echo "Port ${REQUESTED_PORT} in use, using port ${PORT} instead" >&2
  fi
fi

# Resolve symlinks in a path (macOS: /var → /private/var, etc.).
# Uses cd + pwd -P for portability (works on macOS and Linux).
resolve_path() {
  (cd "$1" && pwd -P) 2>/dev/null || printf '%s\n' "$1"
}

# Detect git root on the host. If we're inside a git repo, mount the repo root
# as /code so the container can discover .git and correctly identify the project.
# This matches how native opencode works — project boundaries are git roots.
# If git is not available or we're not in a repo, fall back to $PWD.
PWD_RESOLVED=$(resolve_path "$PWD")
if [[ -z "${OPENCODE_NO_GIT_ROOT:-}" ]] && command -v git >/dev/null 2>&1; then
  GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
  if [[ -n "${GIT_ROOT:-}" ]]; then
    CODE_DIR=$(resolve_path "$GIT_ROOT")
    PROJECT_ID=$(echo -n "$CODE_DIR" | base64 | tr -d '\n' | tr '+/' '-_' | tr -d '=')
  else
    CODE_DIR="$PWD_RESOLVED"
    PROJECT_ID=$(echo -n "$PWD_RESOLVED" | base64 | tr -d '\n' | tr '+/' '-_' | tr -d '=')
  fi
else
  CODE_DIR="$PWD_RESOLVED"
  PROJECT_ID=$(echo -n "$PWD_RESOLVED" | base64 | tr -d '\n' | tr '+/' '-_' | tr -d '=')
fi

DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/opencode/$PROJECT_ID"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/$PROJECT_ID"
LABEL_KEY="opencode.project.id"

if [[ -n "${GIT_ROOT:-}" ]] && [[ "$CODE_DIR" != "$PWD_RESOLVED" ]]; then
  echo "Git repo detected; mounting root: $CODE_DIR" >&2
fi

mkdir -p "$DATA_DIR" "$CONFIG_DIR"

# Prevent duplicate containers for the same project using the full label value
RUNNING_NAME=$(podman ps --filter "label=${LABEL_KEY}=${PROJECT_ID}" --format '{{.Names}}' | head -n1)
if [[ -n "$RUNNING_NAME" ]]; then
  echo "opencode is already running for this project: ${RUNNING_NAME}"
  echo "Attach with: podman attach ${RUNNING_NAME}"
  exit 1
fi

# Common podman args (no --name — let Podman auto-generate to avoid collisions)
PODMAN_ARGS=(
  --label "${LABEL_KEY}=${PROJECT_ID}"
  -v "${DATA_DIR}:/home/opencode/.local/share/opencode:Z"
  -v "${CONFIG_DIR}:/home/opencode/.config/opencode:Z"
  -v "${CODE_DIR}:/code:Z"
  -e OPENCODE_DISABLE_DEFAULT_PLUGINS=true
)

if [[ "$IS_WEB" == true ]]; then
  # Start container in background; set EXIT trap BEFORE podman run so
  # cleanup fires on Ctrl+C, error, or normal exit
  podman run -i --rm --init \
    "${PODMAN_ARGS[@]}" \
    -p "${PORT}:${PORT}" \
    "${IMAGE}" \
    "$@" --hostname 0.0.0.0 --port "${PORT}" &
  CONTAINER_PID=$!

  # Wait briefly for Podman to register the container, then look up its name
  CONTAINER_NAME=""
  for _ in {1..20}; do
    CONTAINER_NAME=$(podman ps --filter "label=${LABEL_KEY}=${PROJECT_ID}" --format '{{.Names}}' | head -n1)
    [[ -n "$CONTAINER_NAME" ]] && break
    sleep 0.1
  done
  if [[ -n "$CONTAINER_NAME" ]]; then
    CODE_B64=$(printf '%s' '/code' | base64 | tr -d '\n' | tr '+/' '-_' | tr -d '=')
    URL="http://localhost:${PORT}/${CODE_B64}"
    echo "opencode web container: ${CONTAINER_NAME}"
    echo "URL: ${URL}"

    # Auto-open browser (macOS: open, Linux: xdg-open)
    if command -v open >/dev/null 2>&1; then
      open "$URL"
    elif command -v xdg-open >/dev/null 2>&1; then
      xdg-open "$URL"
    fi
  fi

  cleanup() {
    trap - EXIT INT TERM
    echo ""
    echo "Stopping opencode container..."
    local name
    name=$(podman ps --filter "label=${LABEL_KEY}=${PROJECT_ID}" --format '{{.Names}}' | head -n1)
    if [[ -n "$name" ]]; then
      podman stop -t 5 "$name" >/dev/null 2>&1 || true
    fi
    wait $CONTAINER_PID 2>/dev/null || true
  }
  trap cleanup EXIT INT TERM

  # Wait for container; || true prevents set -e from skipping cleanup
  wait $CONTAINER_PID || true
else
  # TUI mode: needs -t for interactive terminal
  podman run -it --rm \
    "${PODMAN_ARGS[@]}" \
    "${IMAGE}" \
    "$@"
fi
